{
  "name": "javdb-autospider-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.ts,.tsx,.js,.cjs,.mjs",
    "lint:fix": "eslint . --ext .vue,.ts,.tsx,.js,.cjs,.mjs --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,js,json,css,md}\"",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:contract": "vitest run --config vitest.contract.config.ts",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts",
    "gen:api-types": "node scripts/fetch-openapi.mjs",
    "dev:api": "wrangler dev",
    "test:server": "vitest run --config vitest.server.config.ts",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
    "cf:deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@vueuse/core": "^11.0.0",
    "axios": "^1.0.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "date-fns": "^3.0.0",
    "hono": "^4.12.22",
    "naive-ui": "^2.40.0",
    "pinia": "^2.0.0",
    "vfonts": "^0.1.0",
    "vue": "^3.5.0",
    "vue-i18n": "^9.0.0",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.20260523.1",
    "@intlify/eslint-plugin-vue-i18n": "^4.0.0",
    "@playwright/test": "^1.48.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/eslint-config-typescript": "^14.0.0",
    "@vue/test-utils": "^2.0.0",
    "axios-mock-adapter": "^2.1.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^26.0.0",
    "openapi-typescript": "^7.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.7",
    "vue-tsc": "^2.0.0",
    "wrangler": "^4.94.0"
  }
}
