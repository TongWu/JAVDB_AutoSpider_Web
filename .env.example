# Docker Compose-level overrides. Copy to .env in the same directory.
# All settings have working defaults; this file just documents the knobs.
#
# All BE service settings (admin credentials, API_SECRET_KEY, JAVDB / qB /
# SMTP / PikPak / Rclone, INGESTION_MODE, GH_ACTIONS_*, etc.) come from
# the MAIN repo's config.py — NOT from this file. See:
#   https://github.com/TongWu/JAVDB_AutoSpider_CICD/blob/main/config.py.example

# Path to the main repo's config.py, relative to docker-compose.yml.
# Default works when the FE repo is nested inside the main repo's directory.
# For sibling-clone layout (e.g. ~/code/JAVDB_AutoSpider_CICD + ~/code/JAVDB_AutoSpider_Web),
# set this to ../JAVDB_AutoSpider_CICD/config.py.
# CONFIG_PY_PATH=../config.py

# GHCR namespace to pull the API image from. Must be lowercase (Docker
# image names are case-sensitive; GHCR enforces lowercase).
# GHCR_OWNER=tongwu

# API image tag — pin to sha-<sha> for reproducible deployments.
# API_TAG=latest

# Host ports
# WEB_PORT=5173
# API_PORT=8100

# Browser-facing API URL the FE uses to talk to the BE.
# For Cloudflare Pages: leave unset (same-origin, default).
# For Docker (local dev): uncomment the line below.
# VITE_API_BASE_URL=http://127.0.0.1:8100
