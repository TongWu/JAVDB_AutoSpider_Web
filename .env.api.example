# Backend service config — copy to .env.api and fill in.
# See main repo's config.py.example for the full list:
# https://github.com/TongWu/JAVDB_AutoSpider_CICD/blob/main/config.py.example

# Storage backend: sqlite (local), d1 (Cloudflare), or dual.
STORAGE_BACKEND=sqlite

# Secret key for JWT signing. MUST be >= 32 chars in production.
API_SECRET_KEY=replace-me-with-a-real-secret-of-at-least-32-chars

# Admin credentials. ADMIN_USERNAME defaults to "admin" if unset.
# ADMIN_PASSWORD is REQUIRED in production. The example file ships a weak
# default ("changeme") so the first `docker compose up` works out of the
# box — CHANGE THIS BEFORE any internet-exposed deployment.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Optional readonly user. Leave both blank to disable readonly login.
# READONLY_USERNAME=readonly
# READONLY_PASSWORD=

# Ingestion mode: local (run spider in-process), github (dispatch workflow_dispatch), or dual.
INGESTION_MODE=local

# JavDB session — paste cookie value OR set credentials for headless login.
# JAVDB_SESSION_COOKIE=
# JAVDB_USERNAME=
# JAVDB_PASSWORD=

# qBittorrent Web UI
# QB_URL=https://192.168.1.100:8080
# QB_USERNAME=admin
# QB_PASSWORD=

# Optional integrations
# PIKPAK_USERNAME=
# PIKPAK_PASSWORD=
# RCLONE_REMOTE=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# GitHub Actions integration tier (none|monitor|edit|admin)
GH_ACTIONS_TIER=none
# GH_ACTIONS_REPO=TongWu/JAVDB_AutoSpider_CICD
# GH_ACTIONS_TOKEN=

# FE -> BE wire URL (default works for colocated compose; override for split)
VITE_API_BASE_URL=http://api:8100
